{
  "$schema": "https://getcomposer.org/schema.json",
  "name": "kleinweb/prevent-wordpress-login",
  "type": "wordpress-plugin",
  "license": "GPL-3.0-or-later",
  "description": "WordPress plugin to prevent accessing the login route.",
  "homepage": "https://github.com/kleinweb/prevent-wordpress-login",
  "authors": [
    {
      "name": "Chris Montgomery",
      "email": "chrismont@temple.edu",
      "homepage": "https://github.com/montchr"
    }
  ],
  "support": {
    "issues": "https://github.com/kleinweb/prevent-wordpress-login/issues"
  },
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.59",
    "kleinweb/php-coding-standards": "^0.6.0",
    "phpstan/extension-installer": "^1.3",
    "phpstan/phpstan-deprecation-rules": "^1.2",
    "roave/security-advisories": "dev-latest",
    "slevomat/coding-standard": "^8.15",
    "squizlabs/php_codesniffer": "^3.7.1",
    "szepeviktor/phpstan-wordpress": "^1.3"
  },
  "config": {
    "allow-plugins": {
      "alleyinteractive/composer-wordpress-autoloader": true,
      "composer/installers": true,
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "phpstan/extension-installer": true
    },
    "optimize-autoloader": true,
    "preferred-install": {
      "*": "dist"
    },
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "scripts": {
    "php-cs-fixer": "php-cs-fixer",
    "phpstan": "phpstan analyse --memory-limit 2G",
    "phpcbf": "phpcbf --extensions=php --standard=$PRJ_ROOT/.phpcs.xml.dist",
    "phpcs": "phpcs --extensions=php --standard=$PRJ_ROOT/.phpcs.xml.dist",
    "lint": ["@phpcs", "@phpstan"],
    "fix": ["@php-cs-fixer fix", "@phpcbf"],
    "post-autoload-dump": ["Roots\\Acorn\\ComposerScripts::postAutoloadDump"]
  }
}
